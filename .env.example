# -----------------------------------------------------------------------------
# GIA PHẢ - MẪU BIẾN MÔI TRƯỜNG CẤU HÌNH (ENVIRONMENT VARIABLES)
# -----------------------------------------------------------------------------
# Hướng dẫn:
# 1. Chép (copy) file này thành ".env.local"
# 2. Điền các giá trị thực tế tương ứng với dự án Supabase của bạn

# Tên của ứng dụng web được hiển thị cho người dùng
SITE_NAME="Gia Phả"

# URL của project Supabase (Lấy từ Settings > API)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"

# Khóa Public (Lấy từ Settings > API > Project API keys > anon / public)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="your-anon-or-public-key"

SUPABASE_SERVICE_ROLE_KEY="your-role-key"
NEXT_PUBLIC_FF_READ_EVENTS=true
NEXT_PUBLIC_FF_WRITE_EVENTS=true
NEXT_PUBLIC_FF_VIETNAMESE_TREE_LAYOUT=true
NEXT_PUBLIC_FF_ROOT_STATS=true
NEXT_PUBLIC_FF_MATERNAL_PATERNAL_VIEW=true
NEXT_PUBLIC_FF_GEDCOM_IMPORT_STAGING=true
NEXT_PUBLIC_FF_ALLOW_LEGACY_CLEANUP=false
NEXT_PUBLIC_FF_READ_FAMILIES=true

DATABASE_BACKUP_URL="your-url-postgresql"
BACKUP_DIR="/opt/giapha-os/backups/database"
BACKUP_KEEP_LAST=14
BACKUP_PREFIX="giapha-db"
BUN_BIN="/home/thuongle/.bun/bin/bun"
